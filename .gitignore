# ============================================
# PUBLIC REPO: docs + metadata (no source)
# ============================================
# Published: README, extension/README, docs hub, ARCHITECTURE, OPENQASM-PRIMER,
# QISKIT-INTEGRATION, PROJECT-STRUCTURE, TIPS-AND-TRICKS, LOCAL-MCP-SETUP,
# DEPLOYMENT-SCENARIOS, deployments hub + client modes, examples/qiskit-bell-export.py,
# LICENSE, CONTRIBUTING, CODE_OF_CONDUCT, mise.toml, icons.

# Ignore everything by default
*

# Project metadata & policy files
!.gitignore
!/LICENSE
!/CONTRIBUTING.md
!/CODE_OF_CONDUCT.md
!/mise.toml
!/README.md
!.env.example

# Secret scan (safe to publish — no credentials)
!/scripts/
/scripts/*
!/scripts/check-secrets.sh

# Published docs
!/docs/
/docs/*
!/docs/README.md
!/docs/ARCHITECTURE.md
!/docs/OPENQASM-PRIMER.md
!/docs/PROJECT-STRUCTURE.md
!/docs/TIPS-AND-TRICKS.md
!/docs/QISKIT-INTEGRATION.md
!/docs/ide/
/docs/ide/*
!/docs/ide/LOCAL-MCP-SETUP.md
!/docs/ide/REMOTE-MCP-SETUP.md
!/docs/ide/EXTENSION-REMOTE-MCP.md
!/docs/deployments/
/docs/deployments/*
!/docs/deployments/DEPLOYMENT-SCENARIOS.md

# Extension README + icons (no source)
!/extension/
/extension/**
!/extension/README.md
!/extension/media/
/extension/media/*
!/extension/media/icon.png
!/extension/media/icon.svg

# Examples (public) — Qiskit export workflow only
!/examples/
/examples/*
!/examples/README.md
!/examples/qiskit-bell-export.py

# Deployments hub + client modes (public) — bridge.mjs stays private
!/deployments/
/deployments/*
!/deployments/README.md
!/deployments/extension-only/
/deployments/extension-only/*
!/deployments/extension-only/README.md
!/deployments/extension-mcp-local/
/deployments/extension-mcp-local/*
!/deployments/extension-mcp-local/README.md
!/deployments/mcp-npm/
/deployments/mcp-npm/*
!/deployments/mcp-npm/README.md
!/deployments/extension-remote-mcp/
/deployments/extension-remote-mcp/*
!/deployments/extension-remote-mcp/README.md
!/deployments/mcp-remote-sse/
/deployments/mcp-remote-sse/*
!/deployments/mcp-remote-sse/README.md
!/deployments/local-bridge/
/deployments/local-bridge/*
!/deployments/local-bridge/README.md
!/deployments/docker-sse/
/deployments/docker-sse/*
!/deployments/docker-sse/README.md
!/deployments/secured-remote/
/deployments/secured-remote/*
!/deployments/secured-remote/README.md
!/deployments/wxo-orchestrate/
/deployments/wxo-orchestrate/*
!/deployments/wxo-orchestrate/README.md
!/deployments/ci-cd/
/deployments/ci-cd/*
!/deployments/ci-cd/README.md

# Code Engine deploy (public) — bridge.mjs stays private (see deployments/code-engine/README.md)
!/deployments/code-engine/
/deployments/code-engine/*
!/deployments/code-engine/README.md
!/deployments/code-engine/DEPLOYMENT-GUIDE.md
!/deployments/code-engine/deploy.sh
!/deployments/code-engine/deploy-ibmcloud.sh
!/deployments/code-engine/generate-mcp-configs.sh
!/deployments/code-engine/check-remote-health.sh
!/deployments/code-engine/setup-remote-mcp.sh
!/deployments/code-engine/IDE-SETUP.md
!/deployments/code-engine/Dockerfile
!/deployments/code-engine/.dockerignore
!/deployments/code-engine/code-engine.yaml
!/deployments/code-engine/mcp-client.json
!/deployments/code-engine/mcp-client-vscode-remote.json
!/deployments/code-engine/mcp-client-cursor-remote.json
!/deployments/code-engine/mcp-configs/
/deployments/code-engine/mcp-configs/*
!/deployments/code-engine/mcp-configs/README.md
!/deployments/code-engine/mcp-configs/*.json
!/deployments/code-engine/mcp-configs/deployed/
/deployments/code-engine/mcp-configs/deployed/*
!/deployments/code-engine/mcp-configs/deployed/README.md

# Workspace MCP template (not live mcp.json)
!.vscode/
.vscode/*
!.vscode/mcp.json.example

# ============================================
# Never publish
# ============================================
Internal/
internal/
.env
.env.*
**/.env
**/.env.*
!**/.env.example
deployments/code-engine/bridge.mjs

# Local MCP configs with resolved CE_ENDPOINT (use mcp.json.example + generate-mcp-configs.sh)
.vscode/mcp.json
**/mcp-configs/deployed/CE_ENDPOINT.txt
**/mcp-configs/deployed/*.json
extension/.env

# Extension source & build output (private dev repo only)
extension/src/
extension/out/
extension/node_modules/
extension/package.json
extension/package-lock.json
extension/esbuild.js
extension/tsconfig.json
extension/scripts/
extension/media/*.js
extension/docs/
packages/
