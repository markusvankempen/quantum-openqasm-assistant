# Quantum OpenQASM Assistant — environment template
# Copy to .env and fill in your values. NEVER commit .env to git.
#
#   cp .env.example .env
#
# Get API key: https://cloud.ibm.com/iam/apikeys
# Get Service CRN: IBM Quantum Platform → your instance

IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_SERVICE_CRN=crn:v1:bluemix:public:quantum-computing:us-east:a/your-account-id:your-instance-id::
IBM_QUANTUM_ENDPOINT=https://us-east.quantum-computing.cloud.ibm.com
IBM_QUANTUM_BACKEND=ibm_fez
